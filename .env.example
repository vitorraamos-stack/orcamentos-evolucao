# Front-end (Vite)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
VITE_OS_FOLDER_BASE=\\\\servidor-pc\\...\\A_Z
VITE_FRONTEND_FORGE_API_KEY=
VITE_FRONTEND_FORGE_API_URL=
VITE_OAUTH_PORTAL_URL=
VITE_APP_ID=

# Vercel Serverless (API) - sem prefixo VITE_
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
ORS_API_KEY=

# Supabase Edge Functions (R2)
# (configurar via `supabase secrets set`)
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=os-artes
# R2_ENDPOINT é opcional. Padrão: https://<R2_ACCOUNT_ID>.r2.cloudflarestorage.com

# Agente Windows/SMB (tools/os-asset-agent)
OS_ASSET_BUCKET=os-artes
SMB_BASE=\\\\filesrv\\A_Z
POLL_INTERVAL_SECONDS=10
PAYMENT_PROOF_BATCH_SIZE=5
